# Docker compose reads .env automatically if you copy this file to .env.
# Do not commit real API keys.

SALES_AI_HTTP_PORT=18084
APP_DEBUG=0
TZ=Asia/Shanghai
PHP_MEMORY_LIMIT=256M
PHP_MAX_EXECUTION_TIME=300
PHP_MAX_INPUT_TIME=300
PHP_UPLOAD_MAX_FILESIZE=20M
PHP_POST_MAX_SIZE=24M
UPLOAD_MAX_SIZE=10485760
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=change-me-now
DEFAULT_ADMIN_NAME=超级管理员
SEED_DEMO_USERS=0

TUZI_API_URL=https://api.tu-zi.com/v1/messages
TUZI_API_KEY=
TUZI_MODEL=claude-sonnet-4-5-20250929

TUZI_BACKUP_API_URL=https://apicdn.tu-zi.com/v1/chat/completions
TUZI_BACKUP_API_KEY=
TUZI_BACKUP_MODEL=claude-sonnet-4-20250514

API_TIMEOUT_THRESHOLD=30
API_CONNECT_TIMEOUT=30
API_TOTAL_TIMEOUT=300
API_RETRY_COUNT=1
API_MAX_TOKENS=2500
API_TEMPERATURE=0.7
MAX_INPUT_LENGTH=8000
MAX_CONTEXT_MESSAGES=10
